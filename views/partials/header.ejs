<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Bengkel Fabrikasi Knalpot Custom Premium untuk Mobil & Motor. Sistem transaksi mandiri, Soundroom Check, dan Booking Jadwal Realtime.' %>">
  <meta name="keywords" content="<%= typeof metaKeywords !== 'undefined' ? metaKeywords : 'Custom Knalpot Mobil, Bengkel Knalpot Terdekat, Exhaust Fullsystem Stainless, Custom Knalpot Motor, Spesialis Knalpot Custom' %>">
  <title>ZRC Exhaust - Bengkel Knalpot Custom & PNP</title>
  <link rel="icon" type="image/png" href="/images/LOGO.png">
  
  <!-- CSS Stylesheets -->
  <link rel="stylesheet" href="/css/style.css">
  
  <!-- Conditional CSS for Soundroom & Admin -->
  <% if (typeof soundroomPage !== 'undefined' && soundroomPage) { %>
    <link rel="stylesheet" href="/css/soundroom.css">
  <% } %>
  <% if (typeof adminPage !== 'undefined' && adminPage) { %>
    <link rel="stylesheet" href="/css/admin.css">
  <% } %>
</head>
<body>

  <% if (typeof adminPage === 'undefined' || !adminPage) { %>
    <!-- Public Customer Header Navbar -->
    <header>
      <a href="/" class="logo" style="display: flex; align-items: center;">
        <img src="/images/logo.png" alt="ZRC Exhaust Logo" style="height: 40px; width: auto; object-fit: contain;">
      </a>
      <nav>
        <a href="/" id="nav-home">Home</a>
        <a href="/catalog" id="nav-catalog">Ready Stock (PNP)</a>
        <a href="/soundroom" id="nav-soundroom">Soundroom Check</a>
        <a href="/order" id="nav-order" class="text-gradient-red" style="font-weight: 700;">Custom Order</a>
        <% if (isAdmin) { %>
          <!--<a href="/minzan/dashboard" class="btn btn-secondary" style="padding: 0.4rem 1rem; font-size: 0.85rem;">Dashboard</a>-->
        <% } else { %>
          <!--<a href="/minzan/login" style="font-size: 0.85rem; color: var(--text-muted);">Admin Login</a>-->
        <% } %>
      </nav>
    </header>
    
    <script>
      // Active nav link highlighting
      const path = window.location.pathname;
      if (path === '/') {
        document.getElementById('nav-home').classList.add('active');
      } else if (path === '/catalog') {
        document.getElementById('nav-catalog').classList.add('active');
      } else if (path === '/soundroom') {
        document.getElementById('nav-soundroom').classList.add('active');
      } else if (path === '/order') {
        document.getElementById('nav-order').classList.add('active');
      }
    </script>
  <% } %>

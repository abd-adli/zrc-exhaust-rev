<% let adminPage = true; %>
<%- include('partials/header') %>

<div class="admin-layout">
  <!-- Sidebar -->
  <%- include('partials/admin_sidebar') %>

  <!-- Main Content Area -->
  <main class="admin-content">
    <header class="admin-header">
      <div>
        <h1 style="font-size: 2rem; font-family: var(--font-display); color: var(--primary);">Kapasitas Slot Booking</h1>
        <p class="admin-title-desc">Atur kapasitas kuota pengerjaan knalpot custom harian untuk menghindari kelebihan antrean di bengkel.</p>
      </div>
    </header>

    <div style="display: grid; grid-template-columns: 0.8fr 1.2fr; gap: 2rem; align-items: start;">
      <!-- Left Panel: Add capacity limit override form -->
      <div class="admin-card-form" style="margin-bottom: 0;">
        <h3 style="font-family: var(--font-display); font-size: 1.25rem; color: var(--primary); margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">Atur Kuota Tanggal</h3>
        
        <form action="/minzan/slots/save" method="POST" style="display: flex; flex-direction: column; gap: 1.2rem;">
          <div class="form-group">
            <label class="form-label" for="date">Pilih Tanggal *</label>
            <!-- Date picker, minimum is today -->
            <input type="date" class="form-input" id="date" name="date" required>
          </div>

          <div class="form-group">
            <label class="form-label" for="maxSlots">Kuota Maksimal Slot *</label>
            <input type="number" class="form-input" id="maxSlots" name="maxSlots" value="3" min="1" max="10" required>
            <span style="font-size: 0.75rem; color: var(--text-secondary); line-height: 1.3; margin-top: 0.2rem;">Jumlah pengerjaan knalpot maksimal yang sanggup diselesaikan oleh teknisi pada tanggal ini.</span>
          </div>

          <button type="submit" class="btn btn-primary" style="margin-top: 0.5rem; width: 100%;">Simpan Kuota 📅</button>
        </form>
      </div>

      <!-- Right Panel: List customized slot dates -->
      <div style="background-color: var(--bg-primary); border: 1px solid var(--border-color); border-radius: 8px; padding: 1.8rem; box-shadow: var(--card-shadow);">
        <h3 style="font-family: var(--font-display); font-size: 1.25rem; margin-bottom: 1.2rem; color: var(--primary);">Jadwal Slot Terdaftar & Overrides</h3>
        
        <div class="table-wrapper">
          <% if (slots.length === 0) { %>
            <div style="text-align: center; padding: 3rem; color: var(--text-muted);">
              Belum ada data kuota slot terdaftar. Kuota default (3 unit/hari) akan berlaku otomatis.
            </div>
          <% } else { %>
            <table>
              <thead>
                <tr>
                  <th>Tanggal</th>
                  <th>Hari</th>
                  <th>Kuota Maksimal</th>
                  <th>Terisi</th>
                  <th style="width: 50px; text-align: center;">Reset</th>
                </tr>
              </thead>
              <tbody>
                <% slots.forEach(function(slot) { %>
                  <%
                    let dateObj = new Date(slot.date);
                    let dayName = dateObj.toLocaleDateString('id-ID', { weekday: 'long' });
                    let avail = slot.maxSlots - slot.bookedSlots;
                    let rowStyle = '';
                    if (avail === 0) rowStyle = 'background-color: #FEF2F2;';
                  %>
                  <tr style="<%= rowStyle %>">
                    <td>
                      <strong><%= slot.date %></strong>
                    </td>
                    <td><%= dayName %></td>
                    <td>
                      <span style="font-weight: 700; color: var(--primary);"><%= slot.maxSlots %> unit</span>
                    </td>
                    <td>
                      <% if (slot.bookedSlots >= slot.maxSlots) { %>
                        <span class="badge payment-unpaid">Penuh (<%= slot.bookedSlots %>)</span>
                      <% } else { %>
                        <span class="badge status-fabrication"><%= slot.bookedSlots %> Terisi</span>
                      <% } %>
                    </td>
                    <td style="text-align: center;">
                      <form action="/minzan/slots/delete/<%= slot.id %>" method="POST" onsubmit="return confirm('Apakah Anda yakin ingin mereset kuota tanggal ini?')">
                        <button type="submit" class="btn-icon delete" title="Reset/Hapus Override">🔄</button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>
    </div>
  </main>
</div>

<script>
  // Set minimum date picker to today
  document.getElementById('date').min = new Date().toISOString().split('T')[0];
</script>

<%- include('partials/footer') %>
